# Hyperliquid
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=

# ---- LLM バックエンド設定 ----
# 使用するバックエンドを選択: copilot_cli | claude_code_cli | codex_cli | gemini_cli | mock
LLM_BACKEND=mock

# GitHub Copilot CLI 認証トークン（fine-grained PAT / "Copilot Requests" 権限が必要）
# GH_TOKEN=ghp_...

# CLI タイムアウト（秒）
# LLM_TIMEOUT=120

# LLM API（API 直接アクセス用。CLI バックエンド使用時は不要）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=

# MySQL
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=magi
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=magi_trade

# App
RISK_PERCENT=1.0
DEFAULT_LEVERAGE=5
MAX_HOLD_HOURS=24
